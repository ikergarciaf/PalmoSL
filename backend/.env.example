# ============================================================
# PALMO IA — Configuracion de entorno
# Copia este archivo como .env y rellena los valores.
# ============================================================

# --- IA (obligatorio para modo completo) --------------------
# Clave de la API de Google Gemini.
# Sin ella, el sistema usa clasificacion por reglas (modo demo).
GEMINI_API_KEY=

# --- Gmail (opcional) ---------------------------------------
# Credenciales OAuth2 para leer y responder emails reales.
GMAIL_CREDENTIALS_FILE=data/credentials.json
GMAIL_TOKEN_FILE=data/token.json

# --- Emails -------------------------------------------------
EMAIL_ATENCION_CLIENTE=atencion@palmosuministro.es
EMAIL_ESCALADO=soporte@palmosuministro.es
EMAIL_COMPRAS=compras@palmosuministro.es

# --- Google Sheets (opcional) --------------------------------
SHEETS_CREDENTIALS_FILE=
SHEETS_ID=

# --- Scheduler -----------------------------------------------
# Hora diaria para calcular predicciones de stock (HH:MM)
HORA_EJECUCION_STOCK=07:30

# Dias extra de margen sobre el lead time del proveedor
DIAS_MARGEN_SEGURIDAD=5

# Semanas de historial de ventas para calcular demanda
SEMANAS_HISTORICO=12

# --- Datos (rutas relativas al directorio backend/) ----------
CSV_VENTAS=data/ventas.csv
CSV_PRODUCTOS=data/productos.csv
JSON_PROVEEDORES=data/proveedores.json
EMAILS_MOCK=data/emails_mock.json
